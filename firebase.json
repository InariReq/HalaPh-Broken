          "fileOutput": "android/app/google-services.json"
        }
      },
      "ios": {
        "default": {
          "projectId": "halaph-d4eaa",
          "appId": "1:416537953878:ios:f97984acd7592e048a5df7",
          "uploadDebugSymbols": false,
          "fileOutput": "ios/Runner/GoogleService-Info.plist"
        }
      },
      "macos": {
        "default": {
          "projectId": "halaph-d4eaa",
          "appId": "1:416537953878:ios:f97984acd7592e048a5df7",
          "uploadDebugSymbols": false,
          "fileOutput": "macos/Runner/GoogleService-Info.plist"
        }
      },
      "dart": {
        "lib/firebase_options.dart": {
          "projectId": "halaph-d4eaa",
          "configurations": {
            "android": "1:416537953878:android:d3baf6ab846b760c8a5df7",
            "ios": "1:416537953878:ios:f97984acd7592e048a5df7",
            "macos": "1:416537953878:ios:f97984acd7592e048a5df7",
