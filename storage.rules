rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isImageUnder(maxSize) {
      return request.resource.size < maxSize
        && request.resource.contentType.matches('image/.*');
    }

    // Profile pictures - signed-in users can read profile pictures.
    // The app currently uploads to:
    // profile_pictures/profile_...
    match /profile_pictures/{imageId} {
      allow read: if signedIn();

      allow write: if signedIn()
        && imageId.matches('profile_.*\\.(jpg|jpeg|png|heic|heif)')
        && isImageUnder(5 * 1024 * 1024);
    }

    // Plan banners - app uploads to:
    // plan_banners/{authUid}/plan_banner_...
    match /plan_banners/{ownerId}/{imageId} {
      allow read: if signedIn();

      allow write: if isOwner(ownerId)
        && imageId.matches('plan_banner_.*\\.(jpg|jpeg|png|webp|heic|heif)')
        && isImageUnder(10 * 1024 * 1024);
    }

    // Plan images - participants can read/write.
    // Kept for existing app compatibility.
    match /plan_images/{planId}/{imageId} {
      allow read: if signedIn();

      allow write: if signedIn()
        && isImageUnder(10 * 1024 * 1024);
    }

    // User uploads - users can only access their own folder.
    match /users/{userId}/{allPaths=**} {
      allow read, write: if isOwner(userId);
    }
  }
}
