rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isPlanParticipant(data) {
      return signedIn()
        && data.participantUids is list
        && request.auth.uid in data.participantUids;
    }

    // Allow read access to all authenticated users for development
    match /{document=**} {
      allow read:if signedIn();
      allow write:if signedIn();
    }

    match /users/{userId}/sync/{document=**} {
      allow read, write:if request.auth != null && request.auth.uid == userId;
    }

    match /publicProfiles/{code} {
      allow read:if signedIn();
      allow create, update:if signedIn()
        && request.resource.data.uid == request.auth.uid;
      allow delete:if signedIn() && resource.data.uid == request.auth.uid;
    }

    match /sharedPlans/{planId} {
      allow read:if signedIn();
      allow create:if signedIn()
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.participantUids is list
        && request.auth.uid in request.resource.data.participantUids;
      allow update:if signedIn()
        && request.resource.data.participantUids is list
        && request.auth.uid in request.resource.data.participantUids;
      allow delete:if signedIn() && resource.data.ownerUid == request.auth.uid;
    }
  }
}

    function isPlanParticipant(data) {
      return signedIn()
        && data.participantUids is list
        && request.auth.uid in data.participantUids;
    }

    match /users/{userId}/sync/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /publicProfiles/{code} {
      allow read: if signedIn();
      allow create, update: if signedIn()
        && request.resource.data.uid == request.auth.uid;
      allow delete: if signedIn() && resource.data.uid == request.auth.uid;
    }

    match /sharedPlans/{planId} {
      allow read: if isPlanParticipant(resource.data);
      allow create: if signedIn()
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.participantUids is list
        && request.auth.uid in request.resource.data.participantUids;
      allow update: if isPlanParticipant(resource.data)
        && request.resource.data.ownerUid == resource.data.ownerUid
        && request.resource.data.participantUids is list
        && request.auth.uid in request.resource.data.participantUids;
      allow delete: if signedIn() && resource.data.ownerUid == request.auth.uid;
    }
  }
}
