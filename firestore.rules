rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isPlanParticipant(data) {
      return signedIn()
        && data.participantUids.hasAny([request.auth.uid]);
    }

    function isValidPlanData(data) {
      return data.title is string
        && data.title.size() > 0
        && data.startDate is timestamp
        && data.endDate is timestamp
        && data.participantUids is list
        && data.createdBy is string;
    }

    function ownerUidUnchangedIfPresent() {
      return !resource.data.keys().hasAny(['ownerUid'])
        || request.resource.data.ownerUid == resource.data.ownerUid;
    }

    function ownerIdUnchangedIfPresent() {
      return !resource.data.keys().hasAny(['ownerId'])
        || request.resource.data.ownerId == resource.data.ownerId;
    }

    function ownerUidRemainsParticipantIfPresent() {
      return !resource.data.keys().hasAny(['ownerUid'])
        || resource.data.ownerUid in request.resource.data.participantUids;
    }

    function ownerIdRemainsParticipantIfPresent() {
      return !resource.data.keys().hasAny(['ownerId'])
        || resource.data.ownerId in request.resource.data.participantUids;
    }

    function authIsNotPlanOwner(data) {
      return data.createdBy != request.auth.uid
        && (!data.keys().hasAny(['ownerUid']) || data.ownerUid != request.auth.uid)
        && (!data.keys().hasAny(['ownerId']) || data.ownerId != request.auth.uid);
    }

    function friendRequestDataInvolvesAuth(data) {
      return (data.keys().hasAny(['fromUid']) && data.fromUid == request.auth.uid)
        || (data.keys().hasAny(['toUid']) && data.toUid == request.auth.uid)
        || (data.keys().hasAny(['senderUid']) && data.senderUid == request.auth.uid)
        || (data.keys().hasAny(['targetUid']) && data.targetUid == request.auth.uid)
        || (data.keys().hasAny(['receiverUid']) && data.receiverUid == request.auth.uid)
        || (data.keys().hasAny(['requesterUid']) && data.requesterUid == request.auth.uid);
    }

    function friendRequestIdInvolvesAuth(requestId) {
      return requestId.matches(request.auth.uid + '_.*')
        || requestId.matches('.*_' + request.auth.uid);
    }

    function isParticipantLeavingPlan() {
      return isPlanParticipant(resource.data)
        && authIsNotPlanOwner(resource.data)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['participantUids', 'updatedAt'])
        && request.resource.data.createdBy == resource.data.createdBy
        && ownerUidUnchangedIfPresent()
        && ownerIdUnchangedIfPresent()
        && request.resource.data.participantUids is list
        && !(request.auth.uid in request.resource.data.participantUids)
        && resource.data.createdBy in request.resource.data.participantUids
        && ownerUidRemainsParticipantIfPresent()
        && ownerIdRemainsParticipantIfPresent()
        && resource.data.participantUids.toSet().difference(request.resource.data.participantUids.toSet()).hasOnly([request.auth.uid])
        && request.resource.data.participantUids.toSet().difference(resource.data.participantUids.toSet()).size() == 0;
    }

    function isAdminUid(uid) {
      return signedIn()
        && exists(/databases/$(database)/documents/admin_users/$(request.auth.uid))
        && get(/databases/$(database)/documents/admin_users/$(request.auth.uid)).data.isActive == true
        && get(/databases/$(database)/documents/admin_users/$(request.auth.uid)).data.role in ['owner', 'editor', 'viewer'];
    }

    function isOwnerAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/admin_users/$(request.auth.uid))
        && get(/databases/$(database)/documents/admin_users/$(request.auth.uid)).data.isActive == true
        && get(/databases/$(database)/documents/admin_users/$(request.auth.uid)).data.role == 'owner';
    }

    // Admin users - self-read for admin login, owner-managed writes.
    match /admin_users/{adminUid} {
      allow get: if signedIn() && request.auth.uid == adminUid;
      allow list: if isOwnerAdmin();
      allow create, update, delete: if isOwnerAdmin();
    }

    // User document - profile access
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdminUid(request.auth.uid);
      allow list: if isAdminUid(request.auth.uid);

      allow create: if isOwner(userId)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.keys().hasOnly(['uid', 'photoUrl', 'avatarUrl', 'updatedAt']);

      allow update: if isOwner(userId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'photoUrl',
          'avatarUrl',
          'updatedAt'
        ]);

      allow delete: if isOwner(userId);
    }

    // User private sync data (profile, friends, plans, etc.)
    match /users/{userId}/sync/{document=**} {
      allow read, write: if isOwner(userId);
    }

    // Favorites collection
    match /users/{userId}/favorites/{favoriteId} {
      allow read, create, update, delete: if isOwner(userId);
    }

    // Friends collection - bidirectional
    match /users/{userId}/friends/{friendId} {
      allow read: if isOwner(userId);

      allow create: if signedIn()
        && request.resource.data.keys().hasOnly([
          'friendUid',
          'friendId',
          'uid',
          'code',
          'friendCode',
          'name',
          'avatarUrl',
          'role',
          'createdAt',
          'updatedAt'
        ])
        && (
          // Owner adding someone to their own friends list
          (isOwner(userId) &&
           request.resource.data.friendUid == friendId &&
           request.resource.data.friendId == friendId &&
           request.resource.data.uid == friendId) ||
          // Reciprocal write: friend adding user back
          (request.auth.uid == friendId &&
           request.resource.data.friendUid == friendId &&
           request.resource.data.friendId == friendId &&
           request.resource.data.uid == friendId)
        );

      allow update: if isOwner(userId) && (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'code', 'friendCode', 'avatarUrl', 'role', 'updatedAt'])
      );

      allow delete: if signedIn() && (
        isOwner(userId) ||
        request.auth.uid == resource.data.friendUid
      );
    }

    // Friend requests - private to recipient (nested path - mirror inbox)
    match /users/{userId}/friend_requests/{requestId} {
      allow read: if isOwner(userId);

      allow create: if signedIn()
        && request.auth.uid == request.resource.data.fromUid
        && request.resource.data.toUid == userId
        && request.resource.data.fromUid != request.resource.data.toUid
        && request.resource.data.status == 'pending'
        && request.resource.data.keys().hasOnly(['fromUid', 'toUid', 'fromCode', 'toCode', 'fromName', 'toName', 'fromAvatarUrl', 'toAvatarUrl', 'status', 'createdAt', 'updatedAt']);

      allow update: if signedIn() && (
        // Recipient can accept or decline
        (isOwner(userId) &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt']) &&
         request.resource.data.status in ['accepted', 'declined']) ||
        // Sender can cancel
        (request.auth.uid == resource.data.fromUid &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt']) &&
         request.resource.data.status == 'cancelled') ||
        // Sender can refresh an existing pending request without changing identity
        (request.auth.uid == resource.data.fromUid &&
         request.resource.data.fromUid == resource.data.fromUid &&
         request.resource.data.toUid == resource.data.toUid &&
         request.resource.data.status == 'pending' &&
         request.resource.data.keys().hasOnly(['fromUid', 'toUid', 'fromCode', 'toCode', 'fromName', 'toName', 'fromAvatarUrl', 'toAvatarUrl', 'status', 'createdAt', 'updatedAt']))
      );

      allow delete: if signedIn()
        && (isOwner(userId) ||
            friendRequestDataInvolvesAuth(resource.data));
    }

    // Friend requests - top-level collection

    function friendRequestResourceHasCurrentUser() {
      return request.auth != null
        && (
          ('fromUid' in resource.data && resource.data.fromUid == request.auth.uid)
          || ('toUid' in resource.data && resource.data.toUid == request.auth.uid)
          || ('senderUid' in resource.data && resource.data.senderUid == request.auth.uid)
          || ('receiverUid' in resource.data && resource.data.receiverUid == request.auth.uid)
          || ('requesterUid' in resource.data && resource.data.requesterUid == request.auth.uid)
          || ('targetUid' in resource.data && resource.data.targetUid == request.auth.uid)
          || ('uid' in resource.data && resource.data.uid == request.auth.uid)
        );
    }

    function friendRequestIdHasCurrentUser(requestId) {
      return request.auth != null
        && (
          requestId == request.auth.uid
          || requestId.matches(request.auth.uid + '_.*')
          || requestId.matches('.*_' + request.auth.uid)
          || requestId.matches('.*_' + request.auth.uid + '_.*')
        );
    }

    match /friendRequests/{requestId} {
      allow delete: if request.auth != null
        && (
          friendRequestResourceHasCurrentUser()
          || friendRequestIdHasCurrentUser(requestId)
        );

      // terminal-account-cleanup-friendRequests-delete
      allow delete: if request.auth != null && (
        requestId.matches(request.auth.uid + '_.*') ||
        requestId.matches('.*_' + request.auth.uid) ||
        resource.data.get('fromUid', '') == request.auth.uid ||
        resource.data.get('toUid', '') == request.auth.uid ||
        resource.data.get('senderUid', '') == request.auth.uid ||
        resource.data.get('receiverUid', '') == request.auth.uid ||
        resource.data.get('requesterUid', '') == request.auth.uid ||
        resource.data.get('targetUid', '') == request.auth.uid ||
        resource.data.get('uid', '') == request.auth.uid
      );

      // No get rule - client should not need to read individual request docs
      // Writes are controlled by create/update/delete rules below
      allow list: if signedIn()
        && (resource.data.fromUid == request.auth.uid ||
            resource.data.toUid == request.auth.uid);

      allow create: if signedIn()
        && request.auth.uid == request.resource.data.fromUid
        && request.resource.data.fromUid != request.resource.data.toUid
        && request.resource.data.status == 'pending'
        && request.resource.data.keys().hasOnly(['fromUid', 'toUid', 'fromCode', 'toCode', 'fromName', 'toName', 'fromAvatarUrl', 'toAvatarUrl', 'status', 'createdAt', 'updatedAt']);

      allow update: if signedIn()
        && resource != null
        && (resource.data.fromUid == request.auth.uid ||
            resource.data.toUid == request.auth.uid)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt', 'createdAt'])
        && request.resource.data.status in ['accepted', 'declined', 'cancelled', 'pending'];

      // Allow sender to re-send existing request (set() may trigger update)
      // Identity fields (fromUid, toUid) must not change; only allowed fields can be updated
      allow update: if signedIn()
        && resource.data.fromUid == request.auth.uid
        && request.resource.data.fromUid == resource.data.fromUid
        && request.resource.data.toUid == resource.data.toUid
        && request.resource.data.status == 'pending'
        && request.resource.data.keys().hasOnly(['fromUid', 'toUid', 'fromCode', 'toCode', 'fromName', 'toName', 'fromAvatarUrl', 'toAvatarUrl', 'status', 'createdAt', 'updatedAt']);

      allow delete: if signedIn()
        && resource != null
        && (friendRequestDataInvolvesAuth(resource.data) ||
            friendRequestIdInvolvesAuth(requestId));
    }

    // Friend codes mapping
    match /friendCodes/{code} {
      allow list: if isAdminUid(request.auth.uid);
      allow read: if signedIn();
      allow create: if signedIn()
        && request.auth.uid == request.resource.data.uid
        && request.resource.data.code == code
        && request.resource.data.keys().hasOnly(['uid', 'code', 'createdAt', 'updatedAt']);
      allow update: if signedIn()
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['code', 'updatedAt']);
      allow delete: if signedIn()
        && resource.data.uid == request.auth.uid;
    }

    // Public profiles - searchable by code only
    match /publicProfiles/{code} {
      allow list: if isAdminUid(request.auth.uid);
      function ownsFriendCode() {
        return exists(/databases/$(database)/documents/friendCodes/$(code))
          && get(/databases/$(database)/documents/friendCodes/$(code)).data.uid == request.auth.uid;
      }

      allow get: if signedIn() && (
        // User reading their own profile
        resource.data.uid == request.auth.uid ||
        // Current owner of this friend code reading or repairing their profile
        ownsFriendCode() ||
        // Friend reading (must already be in user's friend list)
        exists(/databases/$(database)/documents/users/$(request.auth.uid)/friends/$(resource.data.uid))
      );
      allow list: if false;  // NO listing - must know exact code
      allow create: if signedIn()
        && ownsFriendCode()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.code == code
        && request.resource.data.code is string
        && request.resource.data.code.size() == 7
        && request.resource.data.keys().hasOnly(['uid', 'code', 'name', 'email', 'avatarUrl', 'commuterType', 'favoritePlaceIds', 'favoritePlaces', 'createdAt', 'updatedAt']);
      allow update: if signedIn()
        && ownsFriendCode()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.code == code
        && request.resource.data.keys().hasOnly(['uid', 'code', 'name', 'email', 'avatarUrl', 'commuterType', 'favoritePlaceIds', 'favoritePlaces', 'createdAt', 'updatedAt'])
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['uid', 'code', 'name', 'email', 'avatarUrl', 'commuterType', 'favoritePlaceIds', 'favoritePlaces', 'createdAt', 'updatedAt']);
      allow delete: if signedIn() && ownsFriendCode();
    }

    // Shared plans - ONLY participants can read/write
    match /sharedPlans/{planId} {
      allow list: if isAdminUid(request.auth.uid);
      allow get: if signedIn() && isPlanParticipant(resource.data);
      allow list: if signedIn() && isPlanParticipant(resource.data);
      allow create: if signedIn()
        && (request.resource.data.createdBy == request.auth.uid || request.resource.data.ownerUid == request.auth.uid)
        && request.resource.data.participantUids is list
        && request.auth.uid in request.resource.data.participantUids
        && isValidPlanData(request.resource.data);
      allow update: if signedIn() && (
        // Owner can update (must remain owner and participant)
        (resource.data.createdBy == request.auth.uid &&
         request.resource.data.createdBy == resource.data.createdBy &&
         request.resource.data.participantUids is list &&
         request.auth.uid in request.resource.data.participantUids) ||
        // Participant can leave by removing only their own UID.
        isParticipantLeavingPlan() ||
        // Account cleanup: a participant can remove only their own access
        // identifiers and participant start-location entries.
        (isPlanParticipant(resource.data) &&
         authIsNotPlanOwner(resource.data) &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['participantUids', 'collaboratorUids', 'participantStartLocations', 'updatedAt']) &&
         request.resource.data.createdBy == resource.data.createdBy &&
         ownerUidUnchangedIfPresent() &&
         ownerIdUnchangedIfPresent() &&
         request.resource.data.participantUids is list &&
         resource.data.createdBy in request.resource.data.participantUids &&
         ownerUidRemainsParticipantIfPresent() &&
         ownerIdRemainsParticipantIfPresent() &&
         request.resource.data.participantUids.toSet().difference(resource.data.participantUids.toSet()).size() == 0 &&
         request.resource.data.collaboratorUids.toSet().difference(resource.data.collaboratorUids.toSet()).size() == 0 &&
         !(request.auth.uid in request.resource.data.participantUids) &&
         !(request.auth.uid in request.resource.data.collaboratorUids) &&
         !request.resource.data.participantStartLocations.keys().hasAny([request.auth.uid])) ||
        // Any participant can update participant start locations only.
        // App code must only write the current user's own start location entry.
        (isPlanParticipant(resource.data) &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['participantStartLocations', 'updatedAt']) &&
         request.resource.data.createdBy == resource.data.createdBy &&
         request.resource.data.ownerUid == resource.data.ownerUid &&
         request.resource.data.ownerId == resource.data.ownerId &&
         request.resource.data.participantUids == resource.data.participantUids &&
         request.resource.data.collaboratorUids == resource.data.collaboratorUids &&
         request.resource.data.title == resource.data.title &&
         request.resource.data.startDate == resource.data.startDate &&
         request.resource.data.endDate == resource.data.endDate &&
         request.resource.data.itinerary == resource.data.itinerary) ||
        // Editor collaborator can update plan content but cannot change ownership or access lists
        (isPlanParticipant(resource.data) &&
         resource.data.collaboratorUids is list &&
         request.auth.uid in resource.data.collaboratorUids &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['title', 'startDate', 'endDate', 'days', 'itinerary', 'itineraries', 'items', 'destinationIds', 'bannerImage', 'meetingPointName', 'meetingPointAddress', 'meetingPointLatitude', 'meetingPointLongitude', 'participantStartLocations', 'isShared', 'updatedAt', 'version']) &&
         request.resource.data.createdBy == resource.data.createdBy &&
         request.resource.data.ownerUid == resource.data.ownerUid &&
         request.resource.data.ownerId == resource.data.ownerId &&
         request.resource.data.participantUids == resource.data.participantUids &&
         request.resource.data.collaboratorUids == resource.data.collaboratorUids)
      );
      allow delete: if signedIn() && (
        resource.data.createdBy == request.auth.uid ||
        resource.data.ownerUid == request.auth.uid
      );
    }

    // Notifications - private to recipient
    match /users/{userId}/notifications/{notificationId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) ||
        (signedIn() && request.resource.data.toUid == userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    // User activity feed - private to owner
    match /users/{userId}/activity/{activityId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId)
        && request.resource.data.keys() <= ['userId', 'type', 'description', 'timestamp'];
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    // Cached destinations - public read, authenticated write
    match /cached_destinations/{destinationId} {
      allow read: if true;
      allow write: if signedIn()
        && request.resource.data.keys() <= ['id', 'name', 'description', 'location', 'coordinates', 'imageUrl', 'category', 'rating', 'tags', 'updatedAt'];
    }
  }
}
